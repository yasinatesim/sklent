# ---- Vela Commerce environment ----
# Copy to .env and adjust. Never commit real secrets.

# Core
APP_ENV=development
API_PORT=8100
WEB_PORT=3100

# Database
DATABASE_URL=postgres://vela:vela@postgres:5432/vela?sslmode=disable
POSTGRES_USER=vela
POSTGRES_PASSWORD=vela
POSTGRES_DB=vela

# Auth / crypto (generate your own; these are demo-only)
JWT_SECRET=change-me-dev-only-secret
# 32-byte base64 key for AES-256-GCM provider-key encryption
CRYPTO_KEY=ZGV2LW9ubHktMzItYnl0ZS1rZXktcGxlYXNlLXJvdGF0ZSE=
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:3100

# RAG / LLM (optional — offline fallback used when empty)
CHROMA_URL=http://chromadb:8000
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-01

# Payment (Iyzico sandbox)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
PAYMENT_CALLBACK_URL=http://localhost:8100/payments/iyzico/callback
FRONTEND_BASE_URL=http://localhost:3100

# Invoice (GIB e-Arşiv) — leave empty in demo
GIB_USERNAME=
GIB_PASSWORD=
GIB_BASE_URL=https://earsivportaltest.efatura.gov.tr

# Email (SMTP) — leave empty to log instead of send
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Vela Commerce <no-reply@vela.test>

# Marketplace (skeleton)
HB_MERCHANT_ID=
TY_SUPPLIER_ID=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8100
NEXT_PUBLIC_SITE_URL=http://localhost:3100
INTERNAL_API_URL=http://api:8100
